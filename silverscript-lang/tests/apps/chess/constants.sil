// Side encoding.
int constant WHITE = 0;
int constant BLACK = 1;

// Terminal status.
int constant LIVE = 0;
int constant WWIN = 1;
int constant BWIN = 2;
int constant DRAW = 3;

// Route-side termination intent.
int constant CLEAR = 0;
int constant OFFER = 1;
int constant CLAIM = 2;
int constant SURRENDER = 3;
int constant ACCEPT = 4;

// Template selector.
int constant PAWN = 0;
int constant KNIGHT = 1;
int constant VERT = 2;
int constant HORIZ = 3;
int constant DIAG = 4;
int constant KING = 5;
int constant CASTLE = 6;
int constant PREP = 7;
int constant MUX = 8;

// Draw substate.
int constant CLAIMED = 1;
int constant DEFENSE = 2;
int constant NORMAL = 3;
int constant WOFFER = 4;
int constant BOFFER = 5;
